		"test:watch": "vitest"
	},
	"peerDependencies": {
		"emdash": "^0.16.0"
	},
	"devDependencies": {
		"astro": "^6.0.0",
		"emdash": "^0.16.1",
		"typescript": "^5.6.0",
		"vitest": "^4.1.8"
	}
